{
  "name": "elttl-remix",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "cf-typegen": "wrangler types",
    "deploy": "react-router build && wrangler deploy",
    "dev": "react-router dev",
    "dev:app": "wrangler dev",
    "dev:db": "turso dev --db-file db/local.db",
    "dev:full": "concurrently -k -n 'dev,app,db' -c 'red,blue,green' \"npm run dev\" \"npm run dev:app\" \"npm run dev:db\"",
    "postinstall": "wrangler types",
    "preview": "react-router build && vite preview",
    "typecheck": "wrangler types && react-router typegen && tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@fontsource/open-sans": "^5.2.7",
    "@libsql/client": "^0.17.3",
    "classnames": "^2.5.1",
    "dayjs": "^1.11.21",
    "drizzle-orm": "^0.45.2",
    "html-react-parser": "^6.1.3",
    "http-status-codes": "^2.3.0",
    "isbot": "^5.1.36",
    "lodash": "^4.18.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-icons": "^5.6.0",
    "react-router": "7.16.0",
    "react-select": "^5.10.2",
    "react-simple-wysiwyg": "^3.4.1",
    "recharts": "^3.9.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.29.1",
    "@react-router/dev": "7.16.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.9",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.19.1",
    "source-map-explorer": "^2.5.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "wrangler": "^4.75.0"
  }
}
