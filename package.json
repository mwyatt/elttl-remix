{
  "name": "elttl-remix",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "cf-typegen": "wrangler types",
    "deploy": "react-router build && wrangler deploy",
    "dev": "react-router dev",
    "dev:app": "wrangler dev",
    "dev:db": "turso dev --db-file db/local.db",
    "dev:full": "concurrently -k -n 'dev,app,db' -c 'red,blue,green' \"npm run dev\" \"npm run dev:app\" \"npm run dev:db\"",
    "postinstall": "wrangler types",
    "preview": "react-router build && vite preview",
    "typecheck": "wrangler types && react-router typegen && tsc -b"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "drizzle-orm": "^0.45.2",
    "isbot": "^5.1.36",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "7.16.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.29.1",
    "@react-router/dev": "7.16.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "wrangler": "^4.75.0"
  }
}
